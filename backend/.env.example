PORT=3001
NODE_ENV=development

# Chemins serveur (à adapter sur le VPS)
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
APPS_ROOT=/var/www
VPS_PUBLIC_IP=

# OVH API — https://eu.api.ovh.com/createToken/
OVH_ENDPOINT=ovh-eu
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=

# Let's Encrypt
CERTBOT_EMAIL=admin@example.com

# Mode démo (sans accès root/nginx réel)
DEMO_MODE=true

# Opérations privilégiées via sudo (recommandé en production)
USE_SUDO=true
DEPLOY_USER=deploy
WEB_GROUP=www-data

# Exclure le manager lui-même de la liste des apps gérées
MANAGER_DOMAINS=manager.example.com
MANAGER_NGINX_CONFIGS=vps-manager.conf,vps-app-manager.conf

# Dossiers Nginx à scanner (séparés par des virgules)
# NGINX_SCAN_DIRS=/etc/nginx/sites-enabled,/etc/nginx/conf.d

# Authentification (OBLIGATOIRE)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
# Ou préférez un hash bcrypt (recommandé en production) :
# ADMIN_PASSWORD_HASH=
JWT_SECRET=changez-ce-secret-par-une-valeur-aleatoire-de-32-caracteres-minimum
SESSION_MAX_AGE=24h
