PORT=3001
NODE_ENV=development

# Chemins serveur (à adapter sur le VPS)
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
APPS_ROOT=/var/www
VPS_PUBLIC_IP=

# OVH API — https://eu.api.ovh.com/createToken/
OVH_ENDPOINT=ovh-eu
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=

# Let's Encrypt
CERTBOT_EMAIL=admin@example.com

# Mode démo (sans accès root/nginx réel)
DEMO_MODE=true

# Authentification (OBLIGATOIRE)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
# Ou préférez un hash bcrypt (recommandé en production) :
# ADMIN_PASSWORD_HASH=
JWT_SECRET=changez-ce-secret-par-une-valeur-aleatoire-de-32-caracteres-minimum
SESSION_MAX_AGE=24h
